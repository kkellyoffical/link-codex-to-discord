# Discord
DISCORD_BOT_TOKEN=replace_me
DISCORD_ALLOWED_USERS=123456789012345678
DISCORD_ALLOWED_GUILDS=123456789012345678
DISCORD_ALLOWED_CHANNELS=123456789012345678

# Codex
CODEX_EXECUTABLE=codex
CODEX_TMUX_TARGET=codex:0.0

# Bridge runtime
BRIDGE_RUNTIME=codex
BRIDGE_DEFAULT_MODE=code
BRIDGE_DEFAULT_MODEL=gpt-5.4
BRIDGE_DEFAULT_WORKDIR=/path/to/workspace

# Optional stream controls
DISCORD_STREAM_INTERVAL_MS=1500
DISCORD_STREAM_MAX_CHARS=1900

