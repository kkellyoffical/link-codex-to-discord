<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.link-codex-to-discord</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>node</string>
    <string>/opt/link-codex-to-discord/dist/daemon.mjs</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/opt/link-codex-to-discord</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>CTI_HOME</key>
    <string>/opt/link-codex-to-discord/.runtime-home</string>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/link-codex-to-discord.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/link-codex-to-discord.log</string>
</dict>
</plist>
